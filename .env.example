NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# When "true", find-prices, aggregate-reviews, and enrich all skip the
# Anthropic API call and use the fixtures in lib/fixtures/ instead.
# Downstream logic (parsing, sorting, validation, database writes)
# still runs normally. Unset or "false" for a live run.
MOCK_TOOLS=false

# HTTP Basic Auth for the whole app. Leave both unset for local dev
# (auth is skipped entirely so localhost keeps working without login).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
